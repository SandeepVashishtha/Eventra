# ============================================
# DOCUMENTATION
# ============================================
# For complete environment setup documentation, see:
# docs/ENV_SETUP_GUIDE.md
#
# This guide covers:
# - Detailed variable explanations
# - Feature enable/disable matrix
# - Troubleshooting common issues
# - Security & deployment guidelines
# - Development workflow best practices
# ============================================

# ============================================
# REQUIRED: API Configuration
# ============================================
# Backend API endpoint (local development)
REACT_APP_API_URL=http://localhost:8080/api

# Use real backend API (true) or mock data (false)
# Set to false for frontend-only development without running backend
REACT_APP_USE_REAL_API=false

# Optional SSE endpoint for real-time streams
# Defaults to REACT_APP_API_URL when omitted
REACT_APP_SSE_URL=http://localhost:4001

# ============================================
# OPTIONAL: Feature Toggles
# ============================================
# Threshold days configuration (keep as is unless changed)
DAYS_THRESHOLD=30

# SECURITY WARNING: GitHub API Token
# ==================================================================
# GitHub tokens MUST NEVER use REACT_APP_ prefix (frontend-exposed variables).
#
# Instead, configure the GitHub token on the BACKEND ONLY:
#   Backend should set: GITHUB_TOKEN=your_github_token (not REACT_APP_*)
#
# All GitHub API requests must route through /api/github-proxy
# which will use the backend's configured GitHub token.
#
# The backend proxy handles:
#   - Rate limit pooling
#   - Secure token usage
#   - CORS handling
#   - Request validation
# ==================================================================

# ============================================
# OPTIONAL: EmailJS (Contact Form & Emails)
# ============================================
# Get these from EmailJS Dashboard: https://dashboard.emailjs.com
# All three must be set for email features to work
# If missing: Contact form shows but emails may not send
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# ============================================
# OPTIONAL: GitHub Integration - BACKEND ONLY
# ============================================
# +-------------------------------------------------------------------------+
# |  DANGER - DO NOT ADD REACT_APP_GITHUB_TOKEN HERE                        |
# |                                                                         |
# |  Any variable prefixed with REACT_APP_ is statically embedded into      |
# |  the compiled JavaScript bundle by Create React App / Vite. A GitHub    |
# |  token placed here would be publicly readable by anyone who opens       |
# |  DevTools or downloads the production bundle.                           |
# |                                                                         |
# |  GitHub tokens MUST be configured as a server-side environment variable |
# |  only - in your backend process or in the Vercel dashboard under        |
# |  Settings -> Environment Variables with scope set to "Server" only.      |
# |                                                                         |
# |  Correct key name (backend / Vercel server-side):                       |
# |    GITHUB_TOKEN=ghp_your_token_here                                     |
# |                                                                         |
# |  All GitHub API calls in the frontend must route through:               |
# |    /api/github-proxy  (see api/github-proxy.js)                         |
# |  which reads GITHUB_TOKEN server-side and never exposes it to clients.  |
# +-------------------------------------------------------------------------+
#
# Backend-only entry (place in your server .env, NOT this file):
#   GITHUB_TOKEN=ghp_your_personal_access_token

# ============================================
# OPTIONAL: Social Authentication
# ============================================
# Facebook App ID (if implementing Facebook OAuth)
REACT_APP_FACEBOOK_APP_ID=your_facebook_app_id_here

# Centralized Telemetry & Sentry Exception Logging
REACT_APP_SENTRY_DSN=your_sentry_dsn_here


VITE_GOOGLE_CLIENT_ID=your_google_client_id