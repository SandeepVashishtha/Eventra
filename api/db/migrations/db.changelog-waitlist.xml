<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="create-event-waitlist-table" author="eventra-agent">
        <createTable tableName="event_waitlist">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="joined_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="waiting">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint
            columnNames="user_id, event_id"
            constraintName="uq_user_event_waitlist"
            tableName="event_waitlist"/>
        <addForeignKeyConstraint
            baseColumnNames="event_id"
            baseTableName="event_waitlist"
            constraintName="fk_event_waitlist_event"
            referencedColumnNames="id"
            referencedTableName="events"
            onDelete="CASCADE"/>
    </changeSet>
</databaseChangeLog>
