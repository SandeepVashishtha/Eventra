# ============================================
# Eventra Production Environment Template
# ============================================
# This file contains production-optimized default settings for Eventra.
# Copy this file to .env.production and fill in your actual production values.

# --------------------------------------------
# Backend Connection
# --------------------------------------------
# Set the primary backend URL. Use VITE_API_URL for modern Vite builds.
VITE_API_URL=https://api.yourproductiondomain.com
BACKEND_URL=https://api.yourproductiondomain.com
REACT_APP_API_URL=https://api.yourproductiondomain.com

# Always use real API in production
REACT_APP_USE_REAL_API=true

# --------------------------------------------
# Frontend Security
# --------------------------------------------
# Enforce strict CSRF protection in production
VITE_CSRF_ENFORCEMENT_MODE=strict

# Optional: Set valid CSP reporting endpoint
REACT_APP_CSP_REPORT_URI=https://your-domain.report-uri.com/r/d/csp/enforce

# --------------------------------------------
# Server-side Secrets (Set in deployment dashboard, e.g. Vercel)
# --------------------------------------------
# CRITICAL: JWT signing secret MUST be set
# Generate securely: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here

# REQUIRED: Persistent authentication storage
DATABASE_URL=postgresql://user:password@host:5432/database

# --------------------------------------------
# Rate Limiting & Distributed Infrastructure
# --------------------------------------------
# REQUIRED: Redis URL for production distributed rate limiting
RATE_LIMIT_REDIS_URL=redis://your_production_redis_host:6379

# Enforce distributed mode in production
RATE_LIMIT_MODE=distributed

# Fallback mode for high availability (fallback to memory if Redis fails)
RATE_LIMIT_FAIL_MODE=fallback

# --------------------------------------------
# Third-party Integrations
# --------------------------------------------
# GitHub Token for leaderboard APIs (Server-side only)
GITHUB_TOKEN=your_github_personal_access_token

# Google OAuth for Sign-in
REACT_APP_GOOGLE_CLIENT_ID=your_production_google_client_id.apps.googleusercontent.com

# Sentry DSN for client-side error monitoring
REACT_APP_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# --------------------------------------------
# Access Control
# --------------------------------------------
# Comma-separated list of allowed CORS origins for API
ALLOWED_ORIGINS=https://yourproductiondomain.com,https://www.yourproductiondomain.com

# Geoblocking (Optional)
# BLOCKED_COUNTRIES=CU,IR,KP,SY,RU
